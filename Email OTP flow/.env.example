# ── HostAfrica cPanel SMTP ─────────────────────────────────────────
# Get EMAIL_HOST from: cPanel → Email Accounts → Connect Devices
# It will look like: mail.yourdomain.com
EMAIL_HOST=mail.yourdomain.com
EMAIL_USER=noreply@yourdomain.com
EMAIL_PASS=your_email_password
EMAIL_FROM="My App <noreply@yourdomain.com>"

# Ports are hardcoded in otp-server.js — no need to change them:
# SMTP = 587  (used for SENDING emails via Nodemailer)
# IMAP = 993  (used by email clients like Outlook to READ emails — not needed here)

# ── OTP Settings ───────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ── Server ─────────────────────────────────────────────────────────
PORT=4000
