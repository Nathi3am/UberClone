# ── HostAfrica cPanel SMTP ─────────────────────────────────────────
# Get EMAIL_HOST from: cPanel → Email Accounts → Connect Devices
# It will look like: mail.yourdomain.com
EMAIL_HOST=mail.yourdomain.com
EMAIL_USER=noreply@yourdomain.com
EMAIL_PASS=your_email_password
EMAIL_FROM="My App <noreply@yourdomain.com>"

# Ports are hardcoded in otp-server.js — no need to change them:
# SMTP = 587  (used for SENDING emails via Nodemailer)
# IMAP = 993  (used by email clients like Outlook to READ emails — not needed here)

# ── OTP Settings ───────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ── Server ─────────────────────────────────────────────────────────
PORT=4000
# Copy this file to .env and fill the values before running the backend


# MongoDB Atlas connection string example (fill in your username and password)
# MONGO_URI=mongodb://<username>:<password>@ac-jmzpt7q-shard-00-00.sf1stco.mongodb.net:27017,ac-jmzpt7q-shard-00-01.sf1stco.mongodb.net:27017,ac-jmzpt7q-shard-00-02.sf1stco.mongodb.net:27017/peakuber?tls=true&replicaSet=atlas-yxrman-shard-0&authSource=admin&retryWrites=true&w=majority
MONGO_USER=yourAtlasUser
MONGO_PASS=yourAtlasPassword
MONGO_CONTEXT_URL=cluster0.mongodb.net/uberdb?retryWrites=true&w=majority

# JWT secret used to sign auth tokens
JWT_SECRET=change_this_to_a_secure_random_string

# Google Maps API key (optional, used by maps service)
GOOGLE_MAPS_API=your_google_maps_api_key

# ── Cloudinary (image hosting) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Backend port (optional)
PORT=4000

# Notes:
# - After copying to `backend/.env`, ensure the values are correct for your Atlas cluster.
# - Keep secrets out of source control.
